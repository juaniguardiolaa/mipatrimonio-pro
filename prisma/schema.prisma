generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  CRYPTO
  STOCK
  CEDEAR
  BOND
  ETF
  CASH
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  name            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accountsAuth    Account[]
  sessions        Session[]
  portfolios      Portfolio[]
  holdingAccounts HoldingAccount[]
  assets          Asset[]
  netWorthHistory NetWorthHistory[]
  snapshots       Snapshot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Portfolio {
  id               String   @id @default(cuid())
  name             String
  userId           String
  totalMarketValue Float    @default(0)
  totalCostBasis   Float    @default(0)
  netWorth         Float    @default(0)
  netWorthUsd      Float    @default(0)
  baseCurrency     String   @default("ARS")
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  holdingAccounts  HoldingAccount[]
  assets           Asset[]
}

model HoldingAccount {
  id          String    @id @default(cuid())
  userId      String
  portfolioId String?
  name        String
  institution String
  type        String
  balance     Float     @default(0)
  currency    String    @default("ARS")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])
  assets      Asset[]

  @@index([userId])
  @@index([portfolioId])
}

model Asset {
  id              String     @id @default(cuid())
  userId          String
  portfolioId     String
  accountId       String?
  symbol          String
  ticker          String?
  exchange        String?
  assetType       AssetType  @default(STOCK)
  quantity        Float
  purchasePrice   Float
  currency        String     @default("ARS")
  cedearRatio     Float?
  marketPrice     Float?
  marketPriceUsd  Float?
  marketValue     Float?
  marketValueUsd  Float?
  lastPriceUpdate DateTime?
  user            User       @relation(fields: [userId], references: [id])
  portfolio       Portfolio  @relation(fields: [portfolioId], references: [id])
  account         HoldingAccount? @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([portfolioId])
  @@index([symbol])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  symbol    String
  price     Float
  currency  String
  source    String
  timestamp DateTime @default(now())

  @@index([symbol, timestamp(sort: Desc)])
}

model FxRate {
  id        String   @id @default(cuid())
  symbol    String
  rate      Float
  source    String
  timestamp DateTime @default(now())

  @@index([symbol, timestamp(sort: Desc)])
}

model NetWorthHistory {
  id         String   @id @default(cuid())
  userId     String
  netWorthArs Float
  netWorthUsd Float
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, timestamp(sort: Desc)])
}

model Snapshot {
  id            String   @id @default(cuid())
  userId        String
  date          String
  netWorthUsd   Float
  netWorthArs   Float
  totalIncome   Float
  totalExpenses Float
  savingsRate   Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
}
